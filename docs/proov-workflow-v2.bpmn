<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="proov_defs" targetNamespace="http://proov/workflow">
  <bpmn:process id="proov_agent" name="Proov coding-agent workflow" isExecutable="false">
    <bpmn:startEvent id="start" name="Task submitted (REPL / driver)">
      <bpmn:outgoing>f0</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="sess" name="Create Session: Provider + Tools + toolMap + system prompt">
      <bpmn:incoming>f0</bpmn:incoming>
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="gwPF" name="Fresh VISUAL build, no reference, imageModel+key?">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="genRef" name="DESIGN-FIRST: generate_image → reference.png (67)">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="model" name="Model call → normalizeCall → tool call (57)">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:incoming>f22</bpmn:incoming>
      <bpmn:incoming>f25</bpmn:incoming>
      <bpmn:incoming>f28</bpmn:incoming>
      <bpmn:incoming>f31</bpmn:incoming>
      <bpmn:incoming>f34</bpmn:incoming>
      <bpmn:incoming>f37</bpmn:incoming>
      <bpmn:incoming>f42</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="gwValid" name="Valid tool call?">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="nValid" name="Nudge: respond with ONE JSON tool call">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="gwDone" name="tool == done?">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="gwPlan" name="NEW Substantial task, NO plan, first edit? (73)">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="nPlan" name="NEW Nudge: task_write a plan first — decompose (73)">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="appr" name="Approval / safety gate OK? (blocklist + mode)">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f14</bpmn:outgoing>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="nDeny" name="Denial nudge / denial-storm → stop">
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="exec" name="Execute tool (toolMap)">
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:outgoing>f17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="guards" name="Post-tool guards: thrash(59) / replan / anti-stuck">
      <bpmn:incoming>f17</bpmn:incoming>
      <bpmn:outgoing>f18</bpmn:outgoing>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="stopE" name="Stopped: budget / dead-end">
      <bpmn:incoming>f19</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="g1" name="Open checklist tasks remain?">
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f20</bpmn:outgoing>
      <bpmn:outgoing>f21</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="nTasks" name="Nudge: finish &amp; verify each task">
      <bpmn:incoming>f20</bpmn:incoming>
      <bpmn:outgoing>f22</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g2" name="Per-task acceptance check fails? (68)">
      <bpmn:incoming>f21</bpmn:incoming>
      <bpmn:outgoing>f23</bpmn:outgoing>
      <bpmn:outgoing>f24</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="nChecks" name="Run task.check (exit0); report failing">
      <bpmn:incoming>f23</bpmn:incoming>
      <bpmn:outgoing>f25</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g3" name="Task-fidelity: prompt-named lib used nowhere? (58)">
      <bpmn:incoming>f24</bpmn:incoming>
      <bpmn:outgoing>f26</bpmn:outgoing>
      <bpmn:outgoing>f27</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="nFidel" name="Nudge: actually USE the named repo/lib">
      <bpmn:incoming>f26</bpmn:incoming>
      <bpmn:outgoing>f28</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g4" name="Visual-match &lt;95% / beyond-frame? (64/66/72)">
      <bpmn:incoming>f27</bpmn:incoming>
      <bpmn:outgoing>f29</bpmn:outgoing>
      <bpmn:outgoing>f30</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="nVisual" name="compare_regions &gt;=95% vs reference; build full game">
      <bpmn:incoming>f29</bpmn:incoming>
      <bpmn:outgoing>f31</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g5" name="GAME gate problem? served(62)/static(37-61)">
      <bpmn:incoming>f30</bpmn:incoming>
      <bpmn:outgoing>f32</bpmn:outgoing>
      <bpmn:outgoing>f33</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="nGame" name="Fix to the bar: broken/frozen/art/structure/asset/anim/level/vision">
      <bpmn:incoming>f32</bpmn:incoming>
      <bpmn:outgoing>f34</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g6" name="Project-checks fail? typecheck/lint/build/test">
      <bpmn:incoming>f33</bpmn:incoming>
      <bpmn:outgoing>f35</bpmn:outgoing>
      <bpmn:outgoing>f36</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="nProj" name="Feed failure back → repair (bounded)">
      <bpmn:incoming>f35</bpmn:incoming>
      <bpmn:outgoing>f37</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="accept" name="Accept done (inner gates passed)">
      <bpmn:incoming>f36</bpmn:incoming>
      <bpmn:outgoing>f38</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="fv" name="NEW FINAL VERIFY (task + project checks)">
      <bpmn:incoming>f38</bpmn:incoming>
      <bpmn:outgoing>f39</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="gwV" name="NEW verification passed?">
      <bpmn:incoming>f39</bpmn:incoming>
      <bpmn:outgoing>f40</bpmn:outgoing>
      <bpmn:outgoing>f41</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="succ" name="SUCCESS — verified">
      <bpmn:incoming>f40</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="remediate" name="NEW FAIL → detailed failures + GENERATE NEW CHECKLIST of fixes, same model (77)">
      <bpmn:incoming>f41</bpmn:incoming>
      <bpmn:outgoing>f42</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="f0" sourceRef="start" targetRef="sess" />
    <bpmn:sequenceFlow id="f1" sourceRef="sess" targetRef="gwPF" />
    <bpmn:sequenceFlow id="f2" sourceRef="gwPF" targetRef="genRef" name="yes" />
    <bpmn:sequenceFlow id="f3" sourceRef="gwPF" targetRef="model" name="no" />
