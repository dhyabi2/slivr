    <bpmn:sequenceFlow id="f17" sourceRef="exec" targetRef="guards" />
    <bpmn:sequenceFlow id="f18" sourceRef="guards" targetRef="model" name="continue" />
    <bpmn:sequenceFlow id="f19" sourceRef="guards" targetRef="stopE" name="stuck/spin" />
    <bpmn:sequenceFlow id="f20" sourceRef="g1" targetRef="nTasks" name="yes" />
    <bpmn:sequenceFlow id="f21" sourceRef="g1" targetRef="g2" name="no" />
    <bpmn:sequenceFlow id="f22" sourceRef="nTasks" targetRef="model" />
    <bpmn:sequenceFlow id="f23" sourceRef="g2" targetRef="nChecks" name="fail" />
    <bpmn:sequenceFlow id="f24" sourceRef="g2" targetRef="g3" name="pass" />
    <bpmn:sequenceFlow id="f25" sourceRef="nChecks" targetRef="model" />
    <bpmn:sequenceFlow id="f26" sourceRef="g3" targetRef="nFidel" name="miss" />
    <bpmn:sequenceFlow id="f27" sourceRef="g3" targetRef="g4" name="ok" />
    <bpmn:sequenceFlow id="f28" sourceRef="nFidel" targetRef="model" />
    <bpmn:sequenceFlow id="f29" sourceRef="g4" targetRef="nVisual" name="fail" />
    <bpmn:sequenceFlow id="f30" sourceRef="g4" targetRef="g5" name="pass" />
    <bpmn:sequenceFlow id="f31" sourceRef="nVisual" targetRef="model" />
    <bpmn:sequenceFlow id="f32" sourceRef="g5" targetRef="nGame" name="problem" />
    <bpmn:sequenceFlow id="f33" sourceRef="g5" targetRef="g6" name="ok" />
    <bpmn:sequenceFlow id="f34" sourceRef="nGame" targetRef="model" />
    <bpmn:sequenceFlow id="f35" sourceRef="g6" targetRef="nProj" name="fail" />
    <bpmn:sequenceFlow id="f36" sourceRef="g6" targetRef="accept" name="pass/none" />
    <bpmn:sequenceFlow id="f37" sourceRef="nProj" targetRef="model" />
    <bpmn:sequenceFlow id="f38" sourceRef="accept" targetRef="fv" />
    <bpmn:sequenceFlow id="f39" sourceRef="fv" targetRef="gwV" />
    <bpmn:sequenceFlow id="f40" sourceRef="gwV" targetRef="succ" name="pass" />
    <bpmn:sequenceFlow id="f41" sourceRef="gwV" targetRef="remediate" name="FAIL" />
    <bpmn:sequenceFlow id="f42" sourceRef="remediate" targetRef="model" name="next iteration" />
  </bpmn:process>
