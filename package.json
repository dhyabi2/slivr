{
  "name": "slivr",
  "version": "0.23.1",
  "type": "module",
  "description": "Slivr — a fast, low-cost CLI coding agent with a precise anchor-based edit engine (never re-sends whole files). Provider-agnostic via OpenRouter; MCP, multimodal, plan-mode, parallel orchestration.",
  "bin": {
    "slivr": "bin/slivr.mjs"
  },
  "scripts": {
    "selftest": "node selftest.mjs",
    "start": "node bin/slivr.mjs",
    "demo": "node demo.mjs",
    "bench": "node bench/run.mjs",
    "bench:lcb": "node bench/livecodebench.mjs",
    "test": "node selftest.mjs",
    "e2e": "node e2e.mjs",
    "e2e:repl": "python3 test/repl_e2e.py",
    "e2e:upgrade": "node test/upgrade_e2e.mjs"
  },
  "license": "AGPL-3.0-or-later",
  "keywords": [
    "coding-agent",
    "ai-agent",
    "ai-agents",
    "llm",
    "ai",
    "cli",
    "developer-tools",
    "agent",
    "mcp",
    "openrouter",
    "anthropic",
    "openai",
    "claude",
    "gemini",
    "code-generation",
    "command-line",
    "coding-assistant",
    "ai-coding-assistant",
    "claude-code-alternative",
    "aider-alternative"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhyabi2/slivr.git"
  },
  "bugs": {
    "url": "https://github.com/dhyabi2/slivr/issues"
  },
  "homepage": "https://github.com/dhyabi2/slivr#readme",
  "files": [
    "bin/",
    "src/",
    "install.sh",
    "README.md",
    "INVENTION.md",
    "assets/",
    ".slivr/",
    "e2e.mjs",
    "selftest.mjs",
    "test/"
  ]
}
